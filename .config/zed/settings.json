// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "git": {
    "inline_blame": {
      "padding": 6,
    },
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": false,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "default_config_options": {
        "mode": "plan",
      },
    },
  },
  "agent": {
    "dock": "right",
    "notify_when_agent_waiting": "never",
    "tool_permissions": {
      "tools": {
        "search_web": {
          "default": "allow",
        },
        "fetch": {
          "default": "allow",
        },
        "create_directory": {
          "default": "allow",
        },
        "delete_path": {
          "default": "allow",
        },
        "terminal": {
          "default": "allow",
        },
      },
    },
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "provider": "zed.dev",
      "model": "claude-opus-4-6",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "Ayu Mirage",
    "dark": "Ayu Dark",
  },
  "vim_mode": true,
  "terminal": {
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default",
      },
    },
  },
  "format_on_save": "on",
  "load_direnv": "direct",
  "languages": {
    "Markdown": {
      "format_on_save": "off",
    },
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.vscode",
    "**/.venv",
    "**/__marimo__",
  ],
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "diagnostics": {
          "enable": true,
        },
      },
    },
  },
}
